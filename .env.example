# Local app URL for development. In hosted environments set this to your deployed app URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Provider switch:
# - ollama for local development/testing
# - openai for hosted/public demos
LLM_PROVIDER=ollama

# Shared links
SUPPORT_LINK=https://www.example.com/support
NEXT_PUBLIC_SUPPORT_LINK=https://www.example.com/support
NEXT_PUBLIC_TEARDOWN_LINK=https://www.example.com/teardown
INGESTION_SECRET=change-me

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Ollama local mode defaults
# Local default for Ollama. In hosted environments this must point to a reachable Ollama endpoint, not localhost.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:1b
OLLAMA_EMBEDDING_MODEL=embeddinggemma

# OpenAI hosted mode defaults
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
